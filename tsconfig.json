{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./server",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false
  },
  "include": [
    "server/index.ts",
    "server/db.ts",
    "server/auth.ts",
    "server/_core/env.ts",
    "server/_core/context.ts",
    "server/_core/routers/index.ts",
    "server/_core/trpc.ts",
    "server/routes/**/*",
    "server/controllers/**/*",
    "server/models/**/*",
    "server/middlewares/**/*",
    "server/types/**/*",
    "server/router.ts",
    "server/_core/routers.ts",
    "server/_core/systemRouter.ts"
  ],
  "exclude": [
    "server/_core/vite.ts",
    "server/_core/llm.ts",
    "server/_core/dataApi.ts",
    "server/_core/imageGeneration.ts",
    "server/_core/map.ts",
    "server/_core/notification.ts",
    "server/_core/voiceTranscription.ts",
    "server/storage.ts",
    "server/auth.logout.test.ts",
    "vite.config.ts",
    "server/_core/index.ts"
  ]
}
